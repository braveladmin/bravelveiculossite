# Mesmo projeto Supabase usado pelo painel ADM (site/estoque) — só leitura
# pública da view public_vehicles (carros disponíveis), sem dados sensíveis.
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-chave-anon

# Meta Graph API — usado por scripts/postar-instagram-veiculo.js (e pelo /aprovar-post).
# Guia de setup: marketing/automacao-meta-setup.md
META_PAGE_ACCESS_TOKEN=
META_IG_USER_ID=
